<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0a0c10">

  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:padding="24dp">

    <TextView android:id="@+id/editor_title" android:text="Edit Button"
        android:textSize="20sp" android:textStyle="bold" android:textColor="#00e5ff"
        android:letterSpacing="0.15" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginBottom="20dp"/>

    <!-- Icon -->
    <TextView android:text="ICON (emoji)" android:textSize="10sp" android:textColor="#555e7a"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="5dp"/>
    <EditText android:id="@+id/f_icon" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:inputType="text" android:hint="🎮"
        android:hintTextColor="#333" android:textColor="#cdd6f4" android:textSize="22sp"
        android:background="#111520" android:padding="12dp" android:layout_marginBottom="14dp"/>

    <!-- Label -->
    <TextView android:text="LABEL" android:textSize="10sp" android:textColor="#555e7a"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="5dp"/>
    <EditText android:id="@+id/f_label" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:inputType="text" android:hint="Split"
        android:hintTextColor="#333" android:textColor="#cdd6f4" android:textSize="16sp"
        android:background="#111520" android:padding="12dp" android:layout_marginBottom="14dp"/>

    <!-- Action type -->
    <TextView android:text="ACTION TYPE" android:textSize="10sp" android:textColor="#555e7a"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp"/>
    <RadioGroup android:id="@+id/f_type_group" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="14dp">
      <RadioButton android:id="@+id/f_type_keys" android:text="Keys"
          android:textColor="#cdd6f4" android:buttonTint="#00e5ff"
          android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="20dp"/>
      <RadioButton android:id="@+id/f_type_sound" android:text="Sound"
          android:textColor="#cdd6f4" android:buttonTint="#00e5ff"
          android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="20dp"/>
      <RadioButton android:id="@+id/f_type_obs" android:text="OBS"
          android:textColor="#cdd6f4" android:buttonTint="#00e5ff"
          android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </RadioGroup>

    <!-- Keys fields -->
    <LinearLayout android:id="@+id/keys_fields" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical">
      <TextView android:text="KEYS (comma-separated)" android:textSize="10sp" android:textColor="#555e7a"
          android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="5dp"/>
      <EditText android:id="@+id/f_keys" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:inputType="text" android:hint="ctrl,alt,1"
          android:hintTextColor="#333" android:textColor="#cdd6f4" android:textSize="15sp"
          android:background="#111520" android:padding="12dp" android:fontFamily="monospace"
          android:layout_marginBottom="5dp"/>
      <TextView android:text="Examples:  ctrl,alt,1  ·  ctrl,shift,f11  ·  f1  ·  win,d"
          android:textSize="10sp" android:textColor="#3a4460"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_marginBottom="14dp"/>
    </LinearLayout>

    <!-- Sound fields -->
    <LinearLayout android:id="@+id/sound_fields" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
      <TextView android:text="SOUND FILE PATH (on your PC)" android:textSize="10sp" android:textColor="#555e7a"
          android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="5dp"/>
      <EditText android:id="@+id/f_sound" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:inputType="text"
          android:hint="C:\sounds\airhorn.mp3" android:hintTextColor="#333"
          android:textColor="#cdd6f4" android:textSize="13sp" android:background="#111520"
          android:padding="12dp" android:fontFamily="monospace" android:layout_marginBottom="14dp"/>
    </LinearLayout>

    <!-- OBS fields -->
    <LinearLayout android:id="@+id/obs_fields" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
      <TextView android:text="OBS COMMAND" android:textSize="10sp" android:textColor="#555e7a"
          android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="5dp"/>
      <Spinner android:id="@+id/f_obs_command" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:background="#111520"
          android:padding="4dp" android:layout_marginBottom="10dp"/>

      <TextView android:id="@+id/f_obs_scene_label" android:text="SCENE NAME"
          android:textSize="10sp" android:textColor="#555e7a" android:visibility="gone"
          android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="5dp"/>
      <EditText android:id="@+id/f_obs_scene" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:inputType="text" android:visibility="gone"
          android:hint="Gameplay" android:hintTextColor="#333" android:textColor="#cdd6f4"
          android:textSize="15sp" android:background="#111520" android:padding="12dp"
          android:layout_marginBottom="10dp"/>

      <TextView android:id="@+id/f_obs_source_label" android:text="SOURCE / INPUT NAME"
          android:textSize="10sp" android:textColor="#555e7a" android:visibility="gone"
          android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="5dp"/>
      <EditText android:id="@+id/f_obs_source" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:inputType="text" android:visibility="gone"
          android:hint="Mic/Aux" android:hintTextColor="#333" android:textColor="#cdd6f4"
          android:textSize="15sp" android:background="#111520" android:padding="12dp"
          android:layout_marginBottom="10dp"/>

      <TextView android:text="Enable WebSocket in OBS → Tools → WebSocket Server Settings\nStart server with:  python streamer_helper_server.py --obs-password YOUR_PW"
          android:textSize="10sp" android:textColor="#3a4460" android:lineSpacingExtra="3dp"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_marginBottom="14dp"/>
    </LinearLayout>

    <!-- Color -->
    <TextView android:text="COLOR" android:textSize="10sp" android:textColor="#555e7a"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:scrollbars="none" android:layout_marginBottom="16dp">
      <LinearLayout android:id="@+id/color_row" android:layout_width="wrap_content"
          android:layout_height="wrap_content" android:orientation="horizontal"/>
    </HorizontalScrollView>

    <!-- Button size -->
    <TextView android:text="BUTTON WIDTH" android:textSize="10sp" android:textColor="#555e7a"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="5dp"/>
    <RadioGroup android:id="@+id/f_width_group" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="14dp">
      <RadioButton android:id="@+id/f_width_1" android:text="Normal (1×)"
          android:textColor="#cdd6f4" android:buttonTint="#00e5ff" android:checked="true"
          android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="24dp"/>
      <RadioButton android:id="@+id/f_width_2" android:text="Wide (2×)"
          android:textColor="#cdd6f4" android:buttonTint="#00e5ff"
          android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </RadioGroup>

    <!-- Options -->
    <TextView android:text="OPTIONS" android:textSize="10sp" android:textColor="#555e7a"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp"/>

    <CheckBox android:id="@+id/f_confirm_tap"
        android:text="Require double-tap to fire  🔒"
        android:textColor="#cdd6f4" android:textSize="14sp" android:buttonTint="#ff9f00"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"/>

    <CheckBox android:id="@+id/f_haptic"
        android:text="Haptic feedback on press"
        android:textColor="#cdd6f4" android:textSize="14sp" android:buttonTint="#00e5ff"
        android:checked="true"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"/>

    <!-- Action buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
      <Button android:id="@+id/btn_cancel" android:layout_width="0dp" android:layout_weight="1"
          android:layout_height="wrap_content" android:text="CANCEL"
          android:textColor="#cdd6f4" android:backgroundTint="#1e2535" android:layout_marginEnd="8dp"/>
      <Button android:id="@+id/btn_delete" android:layout_width="0dp" android:layout_weight="1"
          android:layout_height="wrap_content" android:text="DELETE"
          android:textColor="#ffffff" android:backgroundTint="#ff3c6e" android:layout_marginEnd="8dp"/>
      <Button android:id="@+id/btn_save" android:layout_width="0dp" android:layout_weight="1"
          android:layout_height="wrap_content" android:text="SAVE"
          android:textColor="#000000" android:backgroundTint="#00e5ff"/>
    </LinearLayout>

  </LinearLayout>
</ScrollView>
